{
  "name": "elemental",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "elemental": "./dist/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "bench": "node --experimental-strip-types ./bench.ts",
    "build": "node --experimental-strip-types ./src/cli/index.ts build",
    "dev": "node --experimental-strip-types ./src/cli/index.ts dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "start": "node dist/server.js",
    "test": "vitest run && playwright test",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "oxc-parser": "^0.126.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
